<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Event title -->
        <TextView
            android:id="@+id/detailTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Event Title"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#212121"
            android:layout_marginBottom="12dp" />

        <!-- Date -->
        <TextView
            android:id="@+id/detailDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Date placeholder"
            android:textSize="16sp"
            android:textColor="#757575"
            android:layout_marginBottom="8dp" />

        <!-- Location -->
        <TextView
            android:id="@+id/detailLocation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Location placeholder"
            android:textSize="16sp"
            android:textColor="#757575"
            android:layout_marginBottom="8dp" />

        <!-- Capacity -->
        <TextView
            android:id="@+id/detailCapacity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Capacity: --"
            android:textSize="16sp"
            android:textColor="#757575"
            android:layout_marginBottom="16dp" />

        <!-- Description -->
        <TextView
            android:id="@+id/detailDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Description placeholder"
            android:textSize="15sp"
            android:textColor="#424242"
            android:lineSpacingMultiplier="1.3"
            android:layout_marginBottom="24dp" />

        <!-- TODO (students): Add a "Register" button here -->
        <!-- TODO (students): Show remaining spots -->

    </LinearLayout>

</ScrollView>
